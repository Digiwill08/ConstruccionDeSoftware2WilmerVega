      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 o 503 por Mongo no disponible', function () {",
              "  pm.expect([200, 503]).to.include(pm.response.code);",
              "});"
