          "raw": "{\n  \"accountNumber\": \"ACC{{$timestamp}}\",\n  \"accountType\": \"SAVINGS\",\n  \"currency\": \"USD\",\n  \"holderId\": {{naturalClientId}},\n  \"initialBalance\": 1500.50\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/accounts",
          "host": [
